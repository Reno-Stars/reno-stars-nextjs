# =============================================================================
# Reno Stars Next.js — Environment Variables
# =============================================================================
#
# This file documents ALL environment variables used by the application.
# Copy to .env.local and fill in values for your environment.
#
# For local development with Docker, see .env.local.example for pre-filled
# defaults that work with `pnpm dev:services`.
#
# =============================================================================


# =============================================================================
# DATABASE (Required)
# =============================================================================

# PostgreSQL connection string.
# - Production (Vercel/Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# - Local dev (Docker):       postgresql://postgres:postgres@localhost:5432/renostars
#
# Driver is auto-detected: URLs containing "neon.tech" use the Neon serverless
# HTTP driver; all others use the standard pg Pool driver.
#
# Required at both runtime AND build time (layout.tsx fetches shared data
# from DB during pre-rendering).
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require


# =============================================================================
# APPLICATION (Required)
# =============================================================================

# Canonical base URL for the site. Used in:
# - sitemap.xml generation
# - robots.txt
# - OpenGraph / metadata URLs
# - hreflang alternate links
#
# Must NOT include a trailing slash.
# Production: https://reno-stars.com
# Local dev:  http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://reno-stars.com


# =============================================================================
# STORAGE
# =============================================================================
#
# Storage origin URL for serving images and other assets. getAssetUrl() in
# lib/storage.ts rewrites hardcoded URLs to use this origin:
#
#   https://reno-stars.com/wp-content/uploads/2025/04/photo.jpg
#   → <STORAGE_ORIGIN>/uploads/2025/04/photo.jpg
#
#   /logo.jpg → <STORAGE_ORIGIN>/logo.jpg
#
# Also configures Next.js image optimization (remotePatterns) and CSP headers
# automatically based on this URL.
#
# Examples:
#   R2 public:  https://pub-xxx.r2.dev
#   MinIO:      http://localhost:9000/reno-stars
#   S3:         https://bucket.s3.amazonaws.com
#
# When unset, getAssetUrl() returns URLs unchanged (hardcoded reno-stars.com).
# NEXT_PUBLIC_STORAGE_PROVIDER=https://pub-xxx.r2.dev

# ---------------------------------------------------------------------------
# Storage seed — S3 API config (for `pnpm storage:seed`)
# ---------------------------------------------------------------------------
# Used by scripts/seed-storage.ts to upload assets via S3 API.
# The S3 API endpoint is separate from the public URL above.
# Not used by the main application at runtime.
#
# S3_ENDPOINT — S3 API endpoint
#   R2:    https://<account-id>.r2.cloudflarestorage.com
#   MinIO: http://localhost:9000
#
# S3_BUCKET — bucket name (e.g. reno-stars)
#
# S3_ACCESS_KEY / S3_SECRET_KEY — S3 API credentials
#   R2:    Create an API token in Cloudflare dashboard → R2 → Manage R2 API Tokens
#   MinIO: minioadmin / minioadmin (docker-compose.yml defaults)
#
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_BUCKET=reno-stars
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key


# =============================================================================
# ADMIN PANEL (Required for /admin)
# =============================================================================

# Password for the admin CMS panel at /admin/login.
# Used for HMAC-signed session cookies (scoped to /admin, httpOnly, 24h expiry).
# Choose a strong password for production.
ADMIN_PASSWORD=change-me-to-a-strong-password


# =============================================================================
# GOOGLE REVIEWS (Optional)
# =============================================================================

# Google Places API key and Place ID for fetching live Google Reviews on the
# homepage. Reviews are cached with 24h revalidation.
#
# 1. Enable the Places API (New) in Google Cloud Console
# 2. Create an API key and restrict it to the Places API
# 3. Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
#
# When unset, the testimonials section is hidden on the homepage.
# GOOGLE_PLACES_API_KEY=AIza...
# GOOGLE_PLACE_ID=ChIJ...


# =============================================================================
# EMAIL NOTIFICATIONS (Optional)
# =============================================================================

# Resend API for sending contact form notifications to your company email.
# When configured, each contact form submission triggers an email notification.
#
# 1. Sign up at https://resend.com and create an API key
# 2. Verify your sending domain or use onboarding@resend.dev for testing
# 3. Set EMAIL_TO to receive notifications at your company email
#
# When unset, contact form submissions are saved to the database but no email
# is sent (a console log indicates the skip).
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=notifications@yourdomain.com
# EMAIL_TO=info@reno-stars.com


# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Google Analytics 4 Measurement ID for tracking pageviews, form submissions,
# phone clicks, and other events.
#
# 1. Create a GA4 property in Google Analytics
# 2. Go to Admin → Data Streams → Web → Select your stream
# 3. Copy the Measurement ID (starts with G-)
#
# When unset, no tracking scripts are loaded.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# =============================================================================
# TESTING (Optional)
# =============================================================================

# Base URL for Playwright E2E tests.
# Default: http://localhost:3000
# BASE_URL=http://localhost:3000

# CI environment flag. Set automatically by most CI providers (GitHub Actions,
# Vercel, etc.). Controls Playwright parallelization and retry behavior.
# CI=true


# =============================================================================
# DEPLOYMENT (Vercel — set in Vercel dashboard, not here)
# =============================================================================

# These variables should be configured in the Vercel dashboard or GitHub
# Secrets, NOT in .env files:
#
# DATABASE_URL          — Neon PostgreSQL connection string
# NEXT_PUBLIC_BASE_URL  — https://reno-stars.com
# ADMIN_PASSWORD        — Admin panel password (strong, unique)
# VERCEL_TOKEN          — Required for CI/CD deployment (GitHub Secrets only)
